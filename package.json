{
  "name": "landing-travelgrin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:frontend",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "npm --prefix frontend run start",
    "lint": "npm --prefix frontend run lint && npm --prefix backend run lint",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "prisma:postgres:generate": "npm --prefix backend run prisma:generate",
    "prisma:postgres:migrate": "npm --prefix backend run prisma:migrate",
    "prisma:postgres:studio": "prisma studio --schema backend/prisma/schema.prisma",
    "prisma:sqlite:generate": "prisma generate --schema backend/prisma/schema.sqlite.prisma",
    "prisma:sqlite:migrate": "prisma migrate dev --schema backend/prisma/schema.sqlite.prisma",
    "prisma:sqlite:studio": "prisma studio --schema backend/prisma/schema.sqlite.prisma",
    "db:seed": "npm --prefix backend run db:seed",
    "prisma:generate": "npm --prefix backend run prisma:generate"
  },
  "dependencies": {
    "@prisma/client": "^6.13.0",
    "bcryptjs": "^2.4.3",
    "country-flag-icons": "^1.5.19",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.536.0",
    "next": "15.4.8",
    "openai": "^5.16.0",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "react-hot-toast": "^2.6.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.27",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.4.5",
    "prisma": "^6.13.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
